# ── Required ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=memento

# LLM proxy key (Emergent.sh provides this; replace with your own if self-hosting)
EMERGENT_LLM_KEY=<your-emergent-llm-key>

# Auth service base URL (Emergent.sh hosted auth)
# Must point at the OAuth exchange endpoint used by /api/auth/session
EMERGENT_AUTH_BASE=https://demobackend.emergentagent.com/auth/v1/env

# ── Frontend origin (used for CORS and cookie domain) ─────────────────────────
# For local dev: http://localhost:3000
# For Vercel:    https://your-app.vercel.app
FRONTEND_BASE_URL=http://localhost:3000

# ── Optional ──────────────────────────────────────────────────────────────────
# Webhook URL for PDF/email export (leave blank to disable)
EXPORT_WEBHOOK_URL=

# ── LLM model config (A/B testing) ────────────────────────────────────────────
# Primary model — used first; falls back to FALLBACK on error
LLM_PRIMARY_PROVIDER=gemini
LLM_PRIMARY_MODEL=gemini-2.5-flash

# Fallback model — used when primary fails
LLM_FALLBACK_PROVIDER=anthropic
LLM_FALLBACK_MODEL=claude-sonnet-4-5-20250929

# Intake model — used for the chat intake structured-extraction step
LLM_INTAKE_PROVIDER=gemini
LLM_INTAKE_MODEL=gemini-2.5-flash
