# ── Required ──────────────────────────────────────────────────────────────────
# URL of your deployed backend (no trailing slash)
# For local dev:  http://localhost:8001
# For Vercel:     https://your-backend.vercel.app   (or Railway / Render URL)
REACT_APP_BACKEND_URL=http://localhost:8001

# ── Optional ──────────────────────────────────────────────────────────────────
# OAuth provider URL — defaults to Emergent.sh hosted auth if unset.
# Set this if you run your own OAuth service or switch providers.
REACT_APP_AUTH_URL=https://auth.emergentagent.com
